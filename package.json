{
  "name": "riff-ai",
  "version": "0.1.0",
  "description": "An open protocol and lightweight runtime for coordinating AI agents around human-defined work.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "riff": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "start": "node dist/cli/index.js"
  },
  "keywords": [
    "ai",
    "agents",
    "coordination",
    "mcp",
    "task-management",
    "protocol"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.12",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "better-sqlite3": "^12.8.0",
    "commander": "^14.0.3",
    "hono": "^4.12.9",
    "ulid": "^3.0.2",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["better-sqlite3"]
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
